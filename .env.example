# Shipyard OS — Environment Configuration
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# The setup wizard (npm run dev → /setup) will auto-create .env.local for you.

# ── OpenClaw Gateway ─────────────────────────────────────────────
# Your local OpenClaw agent runtime. Run `openclaw gateway status` to find these.
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# ── Agent Delivery ───────────────────────────────────────────────
# Where agents send task notifications (telegram, discord, signal, whatsapp)
AGENT_DELIVERY_CHANNEL=telegram
AGENT_DELIVERY_TARGET=

# ── Agent Workspace ──────────────────────────────────────────────
# Directory where agent files live (memory, reports, identity docs)
AGENT_WORKSPACE=~/clawd

# ── Mission Control URL ──────────────────────────────────────────
# Public URL for agent callbacks (use localhost for dev)
NEXT_PUBLIC_MC_URL=http://localhost:3000

# ── Optional: Cost Tracking ──────────────────────────────────────
# Anthropic Admin API key for real usage/cost data
# Get yours at: https://console.anthropic.com/settings/admin-keys
# ANTHROPIC_ADMIN_KEY=sk-ant-admin-...

# ── Optional: GitHub Integration ─────────────────────────────────
# Personal access token for private repo access on /projects page
# GITHUB_TOKEN=ghp_...

# ── Optional: Google Calendar ────────────────────────────────────
# Google account email for calendar integration via gog CLI
# GOG_ACCOUNT=you@gmail.com
